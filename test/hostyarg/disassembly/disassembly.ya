var verb;
fun do(cheese) {
    const n = 1;
    const an = [1, 5, nil, "j"];
    fun do2() {
        var m = verb + " " + string(n) + " " + *cheese;
        print m;
        *cheese = nil;
        struct { int32 i; int j; } x;
        fun do3() {
            x.i = 77777;
            for (var i = 0; i < n; i = 1 + i) m;
            return x;
        }
        return do3();
    }
    return do2();
}

