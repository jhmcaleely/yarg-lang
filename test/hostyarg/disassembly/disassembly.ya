var verb;
fun do(cheese) {
    const n = 1;
    fun do2() {
        var m = verb + " " + string(n) + " " + *cheese;
        print m;
        *cheese = nil;
        struct { int32 i; } x;
        fun do3() {
            x.i = 77777;
            for (var i = 0; i < n; i = 1 + i) m;
            return x;
        }
        return do3();
    }
    return do2();
}

class CheeseMaker {
    init(cheese) {
        this.cheese = cheese;
    }

    ripen() {
        var n = "Enjoy ripened";
        verb = n;
        var tc = new(any);
        *tc = this.cheese;
        print *tc;
        var y = do(tc);
        print *tc;
        print this.cheese;
        return y;
    }
}

class CheeseEater {
    init(cheese) {
        this.cheese = "\"" + cheese + "\"";
    }

    ripen() {
        var n = "Already ripened";
        verb = n;
        var tc = new(any);
        *tc = this.cheese;
        print *tc;
        var y = do(tc);
        print *tc;
        print this.cheese;
        return y;
    }

    eat() {
        print "Eaten";
    }
}

var maker = CheeseMaker("cheddar");
var eater = CheeseEater("cheddar");
var z = maker.ripen(); // expect cheddar
                       // expect Enjoy ripened 1 cheddar
                       // expect nil
                       // expect cheddar
print z.i;             // expect 77777
print maker.cheese;    // expect cheddar
var w = eater.ripen(); // expect "cheddar"
                       // expect Already ripened 1 "cheddar"
                       // expect nil
                       // expect "cheddar"
print w.i;             // expect 77777
eater.eat();           // expect Eaten

fun a1() {
    var u = 1;
    fun a2() {
        print 77.0 + 0.1 * mfloat64(u);         // expect 77.1000
        var u = 2;
        fun a3() {
            print string(80) + "." + string(u); // expect 80.2
            var u = 3;
            var dd = mfloat64("-9.87654E-38");
            print dd;                           // expect -9.87654e-38
            dd = -9.87654E-38;
            print dd;                           // expect -9.87654e-38
            dd = mfloat64("123456341234123412341234123412341234123412342341234123412341234123412341234123412341234123412341234123412341234213412341234123412341234");
            print dd;                           // expect 1.23456e+134
            dd = mfloat64(123456341234123412341234123412341234123412342341234123412341234123412341234123412341234123412341234123412341234213412341234123412341234);
            print dd;                           // expect 1.23456e+134
            dd = -0.1;
            print dd;                           // expect -0.100000
            dd = 1.1;
            print dd;                           // expect 1.10000
            dd = 001.1;
            print dd;                           // expect 1.10000
            dd = 1e99;
            print dd;                           // expect 1.00000e+99
            dd = 0e99;
            print dd;                           // expect 0.00000
            dd = 01e99;
            print dd;                           // expect 1.00000e+99
            dd = 0.0e0099;
            print dd;                           // expect 0.00000
            dd = 0.1e0099;
            print dd;                           // expect 1.10000e+98
            dd = 1.1e99;
            print dd;                           // expect 1.10000e+99
            dd = 01.1e99;
            print dd;                           // expect 1.10000e+99
            dd = 1.01e99;
            print dd;                           // expect 1.01000e+99
            dd = 1e-99;
            print dd;                           // expect 1.00000e-99
            dd = 0e-99;
            print dd;                           // expect 0.00000
            dd = 01e-99;
            print dd;                           // expect 1.00000e-99
            dd = 0.0e-0099;
            print dd;                           // expect 0.00000
            dd = 0.1e-0099;
            print dd;                           // expect 1.00000e-100
            dd = 1.1e-99;
            print dd;                           // expect 1.10000e-99
            dd = 01.1e-99;
            print dd;                           // expect 1.10000e-99
            dd = -1.01e-99;
            print dd;                           // expect -1.01000e-99
        }
        a3();
    }
    a2();
}
a1();

