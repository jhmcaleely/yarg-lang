var verb;
fun do(cheese) {
    const n = 1;
    const an = [1, 5, nil, "j"];
    fun do2() {
        var m = verb + " " + string(n) + " " + *cheese;
        print m;
        *cheese = nil;
        struct { int32 i; } x;
        fun do3() {
            x.i = 77777;
            for (var i = 0; i < n; i = 1 + i) m;
            return x;
        }
        return do3();
    }
    return do2();
}

const xa = [int32(1234),  77.0, int32(33554432)];
const struct { int32 i; mfloat64 f; int32 j; } xy;
xa[0] = int32(4321);
xy.i = xa[0];
xy.f = xa[1];
xy.j = xa[2];
print xy;

class CheeseMaker {
    init(cheese) {
        this.cheese = cheese;
    }

    ripen() {
        var n = "Enjoy ripened";
        verb = n;
        var tc = new(any);
        *tc = this.cheese;
        print *tc;
        var y = do(tc);
        print *tc;
        print this.cheese;
        return y;
    }
}

class CheeseEater {
    init(cheese) {
        this.cheese = "\"" + cheese + "\"";
    }

    ripen() {
        var n = "Already ripened " + string(xy.i);
        verb = n;
        var tc = new(any);
        *tc = this.cheese;
        print *tc;
        var y = do(tc);
        print *tc;
        print this.cheese;
        return y;
    }

    eat() {
        print "Eaten";
    }
}

var maker = CheeseMaker("cheddar");
var eater = CheeseEater("cheddar");
var z = maker.ripen(); // expect cheddar
                       // expect Enjoy ripened 1 cheddar
                       // expect nil
                       // expect cheddar
print z.i;             // expect 77777
print maker.cheese;    // expect cheddar
var w = eater.ripen(); // expect "cheddar"
                       // expect Already ripened 1 "cheddar"
                       // expect nil
                       // expect "cheddar"
print w.i;             // expect 77777
eater.eat();           // expect Eaten

