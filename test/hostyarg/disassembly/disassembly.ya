class CheeseMaker {
    init(cheese) {
        this.cheese = cheese;
    }

    ripen() {
        var n = "Enjoy ripened";
        verb = n;
        var tc = new(any);
        *tc = this.cheese;
        print *tc;
        var y = do(tc);
        print *tc;
        print this.cheese;
        return y;
    }
}

class CheeseEater {
    init(cheese) {
        this.cheese = "\"" + cheese + "\"";
    }

    ripen() {
        var n = "Already ripened " + string(xy.i);
        verb = n;
        var tc = new(any);
        *tc = this.cheese;
        print *tc;
        var y = do(tc);
        print *tc;
        print this.cheese;
        return y;
    }

    eat() {
        print "Eaten";
    }
}

var maker = CheeseMaker("cheddar");
var eater = CheeseEater("cheddar");
var z = maker.ripen(); // expect: cheddar
                       // expect: Enjoy ripened 1 cheddar
                       // expect: nil
                       // expect: cheddar
print z.i;             // expect: 77777
print maker.cheese;    // expect: cheddar
var w = eater.ripen(); // expect: "cheddar"
                       // expect: Already ripened 6666666666555555555544488888888887777777777333 1 "cheddar"
                       // expect: nil
                       // expect: "cheddar"
print w.i;             // expect: 77777
eater.eat();           // expect: Eaten

