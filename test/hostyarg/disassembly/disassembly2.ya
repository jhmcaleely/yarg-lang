fun do(cheese) {
    class CheeseMaker {
        init(cheese) {
            this.cheese = cheese;
        }

        ripen() {
            var n = "Enjoy ripened";
            verb = n;
            var tc = new(any);
            *tc = this.cheese;
            print *tc;
            var y = do(tc);
            print *tc;
            print this.cheese;
            return y;
        }
    }

    class CheeseEater {
        init(cheese) {
            this.cheese = "\"" + cheese + "\"";
        }

        ripen() {
            var n = "Already ripened " + string(xy.i);
            verb = n;
            var tc = new(any);
            *tc = this.cheese;
            print *tc;
            var y = do(tc);
            print *tc;
            print this.cheese;
            return y;
        }

        eat() {
            print "Eaten";
        }
    }

    const n = 1;
    const an = [1, 5, nil, "j"];
    fun do2() {
        var m = verb + " " + string(n) + " " + *cheese;
        print m;
        *cheese = nil;
        struct { int32 i; } x;
        fun do3() {
            x.i = 77777;
            for (var i = 0; i < n; i = 1 + i) m;
            return x;
        }
        return do3();
    }

    var maker = CheeseMaker("cheddar");
    var eater = CheeseEater("cheddar");
    var z = maker.ripen();
    print z.i;
    print maker.cheese;
    var w = eater.ripen();
    print w.i;
    eater.eat();

    return do2();
}

