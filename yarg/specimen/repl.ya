fun repl() {
    print "yarg> ";
    while (true) {
        var line = c_stdin_gets();
        if (line != "") {
            interpret(line);
            print "yarg> ";
        }
        else {
            var feofi = c_stdin_eof(); // c_stdin_gets returns null when pause/continue in lldb
            if (feofi) { // only exit if EOF
                return;
            }
        }
    }
}

repl();